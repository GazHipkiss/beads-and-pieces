<div class="bnp-cart">
  <h1>{{ 'sections.cart.title' | t }}</h1>

  {% if cart.item_count == 0 %}
    <p style="text-align:center;color:#9ca3af;margin-top:3rem;">{{ 'sections.cart.empty' | t }}</p>
    <p style="text-align:center;margin-top:1rem;">
      <a href="{{ routes.all_products_collection_url }}" class="bnp-btn bnp-btn--gold" style="max-width:16rem;margin:0 auto;display:block;">Continue shopping</a>
    </p>
  {% else %}
    {% form 'cart', cart %}
      {% for item in cart.items %}
        <div class="bnp-cart__row">
          <div class="bnp-cart__thumb">
            {% if item.image %}
              <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.image.alt | escape }}" width="80" height="80" loading="lazy">
            {% endif %}
          </div>
          <div style="flex:1;">
            <a href="{{ item.url }}" style="color:#fff;font-family:'Cormorant Garamond',serif;font-size:1.25rem;">{{ item.product.title }}</a>
            {% unless item.product.has_only_default_variant %}
              <p style="color:#9ca3af;font-size:0.875rem;margin:0.25rem 0;">{{ item.variant.title }}</p>
            {% endunless %}
            <p style="color:var(--bnp-gold);font-weight:600;">{{ item.final_line_price | money }}</p>
            <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.5rem;">
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity" style="width:4rem;padding:0.35rem;background:#111;border:1px solid #444;color:#fff;border-radius:0.25rem;">
              <a href="{{ item.url_to_remove }}" style="color:#f87171;font-size:0.875rem;">Remove</a>
            </div>
          </div>
        </div>
      {% endfor %}

      <p style="text-align:right;font-size:1.25rem;margin-top:1.5rem;">
        Subtotal: <span style="color:var(--bnp-gold);font-weight:600;">{{ cart.total_price | money }}</span>
      </p>

      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:flex-end;margin-top:1rem;">
        <button type="submit" name="update" class="bnp-btn" style="background:transparent;border:1px solid var(--bnp-gold);color:var(--bnp-gold);width:auto;padding:0.75rem 1.5rem;">Update cart</button>
        <button type="submit" name="checkout" class="bnp-btn bnp-btn--gold" style="width:auto;min-width:12rem;">{{ 'sections.cart.checkout' | t }}</button>
      </div>
    {% endform %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": []
}
{% endschema %}
